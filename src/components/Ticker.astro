<style>
.ticker {
  position: relative;
  overflow: hidden;
  border-top: 2px solid #961e10;
  border-bottom: 2px solid #961e10;
  background: #fcaf17;
  color: #961e10;
}
.ticker-track {
  display: flex;
  gap: 48px;
  padding: 14px 0 14px 48px;
  white-space: nowrap;
  width: max-content;
  animation: ticker 48s linear infinite;
  font-family: "Alfa Slab One", "Times New Roman", serif;
  font-size: 22px;
  text-transform: uppercase;
  letter-spacing: 0.02em;
}
.em {
  font-family: "Times New Roman", Times, serif;
  font-style: italic;
  font-weight: 700;
  text-transform: none;
}
.dot { color: #6a1509; }
</style>

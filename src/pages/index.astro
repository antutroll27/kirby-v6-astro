---
import Base from '../layouts/Base.astro';
import NoticeBar from '../components/NoticeBar.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import Ticker from '../components/Ticker.astro';
import Work from '../components/Work.astro';
import VSL from '../components/VSL.astro';
import Cases from '../components/Cases.astro';
import Services from '../components/Services.astro';
import Shop from '../components/Shop.astro';
import About from '../components/About.astro';
import Contact from '../components/Contact.astro';
import Footer from '../components/Footer.astro';
---

<Base>
  <NoticeBar />
  <Nav />
  <main id="main-content">
    <Hero />
    <Ticker />
    <Work />
    <VSL />
    <Cases />
    <Services />
    <Shop />
    <About />
    <Contact />
  </main>
  <Footer />
</Base>

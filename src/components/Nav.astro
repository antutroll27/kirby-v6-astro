---
<nav class="nav" aria-label="Primary">
  <a href="#top" class="mark">JK</a>
  <ul>
    <li><a href="#work">Work</a></li>
    <li><a href="#vsl">Reel</a></li>
    <li><a href="#cases">Cases</a></li>
    <li><a href="#services">Services</a></li>
    <li><a href="#shop">Shop</a></li>
    <li><a href="#about">About</a></li>
  </ul>
  <div class="nav-right">
    <a class="cta" href="https://www.upwork.com/freelancers/~01507e9897388a0aed?mp_source=share" target="_blank" rel="noopener noreferrer">Hire on Upwork →</a>
    <button class="hamburger" aria-label="Open menu" aria-expanded="false" aria-controls="mobile-menu" type="button">
      <span></span><span></span><span></span>
    </button>
  </div>
</nav>

<div class="mobile-menu" id="mobile-menu" aria-hidden="true">
  <ul>
    <li><a href="#work">Work</a></li>
    <li><a href="#vsl">Reel</a></li>
    <li><a href="#cases">Cases</a></li>
    <li><a href="#services">Services</a></li>
    <li><a href="#shop">Shop</a></li>
    <li><a href="#about">About</a></li>
  </ul>
  <a class="mobile-cta" href="https://www.upwork.com/freelancers/~01507e9897388a0aed?mp_source=share" target="_blank" rel="noopener noreferrer">Hire on Upwork →</a>
</div>

<script>
  const btn = document.querySelector('.hamburger') as HTMLButtonElement;
  const menu = document.getElementById('mobile-menu')!;
  btn.addEventListener('click', () => {
    const open = btn.getAttribute('aria-expanded') === 'true';
    btn.setAttribute('aria-expanded', String(!open));
    btn.setAttribute('aria-label', open ? 'Open menu' : 'Close menu');
    menu.setAttribute('aria-hidden', String(open));
    menu.classList.toggle('open', !open);
    btn.classList.toggle('active', !open);
  });
  menu.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', () => {
      btn.setAttribute('aria-expanded', 'false');
      btn.setAttribute('aria-label', 'Open menu');
      menu.setAttribute('aria-hidden', 'true');
      menu.classList.remove('open');
      btn.classList.remove('active');
    });
  });
</script>

<style>
.nav {
  position: fixed;
  top: 32px; left: 0; right: 0;
  z-index: 100;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 14px clamp(20px, 4vw, 64px);
  font-family: "JetBrains Mono", ui-monospace, Menlo, monospace;
  font-size: 11px;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: #f6e9c9;
  background: rgba(18,9,5,0.88);
  backdrop-filter: blur(8px);
  border-bottom: 1px solid rgba(246,233,201,0.12);
}
.mark {
  font-family: "Alfa Slab One", "Times New Roman", serif;
  font-size: 24px;
  color: #fcaf17;
  letter-spacing: -0.02em;
  text-transform: uppercase;
  text-shadow: 0 0.06em 0 #961e10;
}
.nav ul {
  list-style: none;
  display: flex;
  gap: 28px;
  margin: 0; padding: 0;
}
.nav a:hover { color: #fcaf17; }
.nav-right { display: flex; align-items: center; gap: 16px; }

.cta {
  padding: 9px 14px;
  background: #fcaf17;
  color: #120905;
  border: 2px solid #961e10;
  font-weight: 500;
  transition: transform 0.15s;
}
.cta:hover { transform: translate(-2px, -2px); box-shadow: 3px 3px 0 #961e10; color: #120905; }

.hamburger {
  display: none;
  flex-direction: column;
  justify-content: center;
  gap: 5px;
  width: 36px; height: 36px;
  background: transparent;
  border: 1px solid rgba(246,233,201,0.32);
  cursor: pointer;
  padding: 8px;
}
.hamburger span {
  display: block;
  width: 100%; height: 2px;
  background: #f6e9c9;
  transition: transform 0.2s, opacity 0.2s;
}
.hamburger.active span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
.hamburger.active span:nth-child(2) { opacity: 0; }
.hamburger.active span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

.mobile-menu {
  position: fixed;
  top: calc(32px + 49px);
  left: 0; right: 0;
  z-index: 99;
  background: rgba(18,9,5,0.96);
  backdrop-filter: blur(12px);
  border-bottom: 2px solid #961e10;
  padding: 24px clamp(20px, 4vw, 64px);
  display: none;
  flex-direction: column;
  gap: 16px;
}
.mobile-menu.open { display: flex; }
.mobile-menu ul {
  list-style: none;
  margin: 0; padding: 0;
  display: flex;
  flex-direction: column;
  gap: 0;
}
.mobile-menu ul li a {
  display: block;
  padding: 14px 0;
  font-family: "JetBrains Mono", ui-monospace, Menlo, monospace;
  font-size: 12px;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: #f6e9c9;
  border-bottom: 1px solid rgba(246,233,201,0.12);
}
.mobile-menu ul li a:hover { color: #fcaf17; }
.mobile-cta {
  display: inline-block;
  margin-top: 8px;
  padding: 12px 20px;
  background: #fcaf17;
  color: #120905;
  border: 2px solid #961e10;
  font-family: "JetBrains Mono", ui-monospace, Menlo, monospace;
  font-size: 12px;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  font-weight: 500;
  align-self: flex-start;
}

@media (max-width: 820px) {
  .nav ul { display: none; }
  .hamburger { display: flex; }
  .cta { display: none; }
}
</style>
